#!/usr/bin/env python3
"""cli-fpp thin entry — runs packaged module without dev extras."""

import sys

if sys.version_info < (3, 10):
    sys.stderr.write(
        f"Python 3.10+ required (current {sys.version_info.major}.{sys.version_info.minor})\n"
    )
    sys.exit(1)

from cli_fpp.__main__ import main

if __name__ == "__main__":
    main()
